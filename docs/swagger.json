{
    "schemes": [
        "http",
        "https"
    ],
    "swagger": "2.0",
    "info": {
        "description": "Encurtador de URLs em Go com AES-256-GCM, deduplicação por HMAC, alias customizado, TTL/expiração, QR code, analytics de clique e métricas Prometheus.\nAs URLs originais são cifradas em repouso; o IP dos acessos é gravado apenas como HMAC (LGPD).",
        "title": "Small Links API",
        "contact": {
            "name": "Small Links"
        },
        "license": {
            "name": "MIT",
            "url": "https://opensource.org/licenses/MIT"
        },
        "version": "1.0"
    },
    "basePath": "/",
    "paths": {
        "/": {
            "get": {
                "description": "Página inicial com formulário de encurtamento.",
                "produces": [
                    "text/html"
                ],
                "tags": [
                    "landing"
                ],
                "summary": "Landing page",
                "responses": {
                    "200": {
                        "description": "HTML da landing page",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/api/links/{shortId}": {
            "delete": {
                "description": "Soft delete via token de gerenciamento (Authorization: Bearer \u003ctoken\u003e). Resposta 403 uniforme quando não autorizado — não revela se o short_id existe. Analytics preservado; redirect/QR passam a 410.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "links"
                ],
                "summary": "Desativa um short link",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Identificador do short link",
                        "name": "shortId",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Bearer \u003cmanagement_token\u003e",
                        "name": "Authorization",
                        "in": "header",
                        "required": true
                    }
                ],
                "responses": {
                    "204": {
                        "description": "Link desativado"
                    },
                    "403": {
                        "description": "Token ausente ou inválido (uniforme)",
                        "schema": {
                            "$ref": "#/definitions/http.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/http.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/api/shorten": {
            "post": {
                "description": "Cria um short link. Campos opcionais: custom_alias e expires_in_days. Se a URL já existir, responde 200 com \"existing\": true.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "shorten"
                ],
                "summary": "Encurta uma URL",
                "parameters": [
                    {
                        "description": "URL e opções",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/http.ShortenRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "URL já existente (dedup)",
                        "schema": {
                            "$ref": "#/definitions/http.ShortenResponse"
                        }
                    },
                    "201": {
                        "description": "Short link criado",
                        "schema": {
                            "$ref": "#/definitions/http.ShortenResponse"
                        }
                    },
                    "400": {
                        "description": "Body ou URL inválidos",
                        "schema": {
                            "$ref": "#/definitions/http.ErrorResponse"
                        }
                    },
                    "409": {
                        "description": "Alias já em uso ou reservado",
                        "schema": {
                            "$ref": "#/definitions/http.ErrorResponse"
                        }
                    },
                    "422": {
                        "description": "URL bloqueada: maliciosa (phishing/malware)",
                        "schema": {
                            "$ref": "#/definitions/http.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/http.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/health": {
            "get": {
                "description": "Retorna status do serviço, total de URLs e timestamp.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "health"
                ],
                "summary": "Health check",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/http.HealthResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/http.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/qr/{shortId}": {
            "get": {
                "description": "Gera o PNG do short_url. Confirma que o link existe antes de gerar. 410 se deletado.",
                "produces": [
                    "image/png"
                ],
                "tags": [
                    "qr"
                ],
                "summary": "QR code de um short link",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Identificador do short link",
                        "name": "shortId",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Imagem PNG",
                        "schema": {
                            "type": "file"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/http.ErrorResponse"
                        }
                    },
                    "410": {
                        "description": "Link desativado",
                        "schema": {
                            "$ref": "#/definitions/http.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/http.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/shorten": {
            "get": {
                "description": "Variante GET mantida por compatibilidade; delega à mesma lógica do POST.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "shorten"
                ],
                "summary": "Encurta uma URL (endpoint legado)",
                "parameters": [
                    {
                        "type": "string",
                        "description": "URL original (http/https)",
                        "name": "url",
                        "in": "query",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/http.ShortenResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/http.ErrorResponse"
                        }
                    },
                    "422": {
                        "description": "URL bloqueada: maliciosa (phishing/malware)",
                        "schema": {
                            "$ref": "#/definitions/http.ErrorResponse"
                        }
                    },
                    "429": {
                        "description": "Too Many Requests",
                        "schema": {
                            "$ref": "#/definitions/http.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/http.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/stats/{shortId}": {
            "get": {
                "description": "Retorna access_count, total_clicks, clicks_per_day (30 dias), top_referrers (top 5), top_countries e devices. Bots (is_bot) ficam fora de todas as agregações; país/device não classificado aparece como \"unknown\". top_countries lista todos os países (sem top-5), de modo que a soma de top_countries e a soma de devices batem com total_clicks.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "stats"
                ],
                "summary": "Estatísticas de um short link",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Identificador do short link",
                        "name": "shortId",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/http.StatsResponse"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/http.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/http.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/{shortId}": {
            "get": {
                "description": "Responde 302 para a URL original. 404 se inexistente, 410 se expirado ou deletado. Link protegido por senha sem cookie de acesso responde a tela de senha (Accept: text/html) ou 401 JSON.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "redirect"
                ],
                "summary": "Redireciona um short link",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Identificador do short link",
                        "name": "shortId",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "302": {
                        "description": "Redirect para a URL original"
                    },
                    "401": {
                        "description": "Link protegido por senha",
                        "schema": {
                            "$ref": "#/definitions/http.ErrorResponse"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/http.ErrorResponse"
                        }
                    },
                    "410": {
                        "description": "Link expirado ou desativado",
                        "schema": {
                            "$ref": "#/definitions/http.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/http.ErrorResponse"
                        }
                    }
                }
            },
            "post": {
                "description": "Aceita `password` via form ou header `X-Password`. Senha correta emite o cookie de acesso assinado (1h, HttpOnly, Path do link) e responde 302 para a URL original, na mesma resposta. Limitado a 5 tentativas por minuto POR LINK.",
                "consumes": [
                    "application/x-www-form-urlencoded"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "redirect"
                ],
                "summary": "Envia a senha de um link protegido",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Identificador do short link",
                        "name": "shortId",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Senha do link",
                        "name": "password",
                        "in": "formData"
                    },
                    {
                        "type": "string",
                        "description": "Senha do link (alternativa ao form)",
                        "name": "X-Password",
                        "in": "header"
                    }
                ],
                "responses": {
                    "302": {
                        "description": "Redirect para a URL original"
                    },
                    "401": {
                        "description": "Senha ausente ou incorreta",
                        "schema": {
                            "$ref": "#/definitions/http.ErrorResponse"
                        }
                    },
                    "404": {
                        "description": "Link inexistente ou sem senha",
                        "schema": {
                            "$ref": "#/definitions/http.ErrorResponse"
                        }
                    },
                    "410": {
                        "description": "Link expirado ou desativado",
                        "schema": {
                            "$ref": "#/definitions/http.ErrorResponse"
                        }
                    },
                    "429": {
                        "description": "Tentativas excedidas para este link",
                        "schema": {
                            "$ref": "#/definitions/http.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/http.ErrorResponse"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "http.CountryCountDoc": {
            "type": "object",
            "properties": {
                "count": {
                    "type": "integer",
                    "example": 25
                },
                "country": {
                    "type": "string",
                    "example": "BR"
                }
            }
        },
        "http.DailyClicksDoc": {
            "type": "object",
            "properties": {
                "count": {
                    "type": "integer",
                    "example": 12
                },
                "day": {
                    "type": "string",
                    "example": "2026-07-10"
                }
            }
        },
        "http.DeviceCountDoc": {
            "type": "object",
            "properties": {
                "count": {
                    "type": "integer",
                    "example": 30
                },
                "device": {
                    "type": "string",
                    "example": "mobile"
                }
            }
        },
        "http.ErrorResponse": {
            "type": "object",
            "properties": {
                "error": {
                    "type": "string",
                    "example": "Short URL not found"
                }
            }
        },
        "http.HealthResponse": {
            "type": "object",
            "properties": {
                "status": {
                    "type": "string",
                    "example": "healthy"
                },
                "timestamp": {
                    "type": "string",
                    "example": "2026-07-10T12:00:00Z"
                },
                "total_urls": {
                    "type": "integer",
                    "example": 123
                }
            }
        },
        "http.ReferrerCountDoc": {
            "type": "object",
            "properties": {
                "count": {
                    "type": "integer",
                    "example": 20
                },
                "referrer": {
                    "type": "string",
                    "example": "https://news.exemplo.com"
                }
            }
        },
        "http.ShortenRequest": {
            "type": "object",
            "properties": {
                "custom_alias": {
                    "type": "string",
                    "example": "promo"
                },
                "expires_in_days": {
                    "type": "integer",
                    "example": 30
                },
                "password": {
                    "description": "Password protege o link: o acesso passa a exigir a senha. Mínimo de 4\ncaracteres. Nunca é devolvida em resposta alguma (o cliente recebe\napenas has_password).",
                    "type": "string",
                    "example": "segredo123"
                },
                "url": {
                    "type": "string",
                    "example": "https://www.exemplo.com/pagina"
                }
            }
        },
        "http.ShortenResponse": {
            "type": "object",
            "properties": {
                "created_at": {
                    "type": "string",
                    "example": "2026-07-10T12:00:00Z"
                },
                "existing": {
                    "type": "boolean",
                    "example": false
                },
                "expires_at": {
                    "type": "string",
                    "example": "2026-08-09T12:00:00Z"
                },
                "has_password": {
                    "description": "HasPassword indica se o link exige senha para abrir. A senha e seu\nhash nunca aparecem em resposta alguma.",
                    "type": "boolean",
                    "example": false
                },
                "management_token": {
                    "description": "ManagementToken é devolvido UMA ÚNICA VEZ, apenas em criação nova\n(nunca no reaproveitamento por dedup). Guarde-o para excluir o link.",
                    "type": "string",
                    "example": "a1b2c3...64hex"
                },
                "original_url": {
                    "type": "string",
                    "example": "https://www.exemplo.com/pagina"
                },
                "short_id": {
                    "type": "string",
                    "example": "promo"
                },
                "short_url": {
                    "type": "string",
                    "example": "https://exemplo.com/promo"
                }
            }
        },
        "http.StatsResponse": {
            "type": "object",
            "properties": {
                "access_count": {
                    "type": "integer",
                    "example": 42
                },
                "clicks_per_day": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/http.DailyClicksDoc"
                    }
                },
                "created_at": {
                    "type": "string",
                    "example": "2026-07-10T12:00:00Z"
                },
                "devices": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/http.DeviceCountDoc"
                    }
                },
                "original_url": {
                    "type": "string",
                    "example": "https://www.exemplo.com/pagina"
                },
                "short_id": {
                    "type": "string",
                    "example": "promo"
                },
                "top_countries": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/http.CountryCountDoc"
                    }
                },
                "top_referrers": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/http.ReferrerCountDoc"
                    }
                },
                "total_clicks": {
                    "type": "integer",
                    "example": 42
                }
            }
        }
    }
}